{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "paths": {
      "@ccmsg/protocol": ["./packages/protocol/src/index.ts"],
      "@ccmsg/daemon": ["./packages/daemon/src/server.ts"],
      "@ccmsg/daemon/run": ["./packages/daemon/src/run.ts"],
      "@ccmsg/daemon/session-dump": ["./packages/daemon/src/session-dump.ts"],
      "@ccmsg/webui": ["./packages/webui/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts", "hooks/**/*.ts", "bin/**/*.ts"],
  "exclude": ["packages/webui/src/client/**", "packages/webui/test/**"]
}
